class Node:
    def __init__(self,value):
        self.data = value
        self.next = None

class Stack:
    def __init__(self):
        self.head = None
    
    def push(self,value):
        new_node = Node(value)
        new_node.next = self.head
        self.head = new_node

    def pop(self):
        if self.head:
            new_node = self.head
            self.head = self.head.next
            return new_node.data

    def peek(self):
        if self.head:
            return self.head.data
        
    def empty(self):
        return self.head is None

class MyQueue(object):

    def __init__(self):
        self.stack_temp = Stack()
        self.stack_fin = Stack()

    def push(self, x):
        """
        :type x: int
        :rtype: None
        """
        self.stack_temp.push(x)

    def pop(self):
        """
        :rtype: int
        """
        if self.stack_fin.empty():
            while not self.stack_temp.empty():
                el = self.stack_temp.peek()
                self.stack_fin.push(el)
                self.stack_temp.pop()
        return self.stack_fin.pop()

    def peek(self):
        """
        :rtype: int
        """
        if self.stack_fin.empty():
            while not self.stack_temp.empty():
                el = self.stack_temp.peek()
                self.stack_fin.push(el)
                self.stack_temp.pop()
        return self.stack_fin.peek()

    def empty(self):
        """
        :rtype: bool
        """
        return self.stack_temp.empty() and self.stack_fin.empty() 
