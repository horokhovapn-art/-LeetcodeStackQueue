class Node:
    def __init__(self,value):
        self.data = value
        self.next = None

class Stack:
    def __init__(self):
        self.head = None
    
    def push(self,value):
        new_node = Node(value)
        new_node.next = self.head
        self.head = new_node

    def pop(self):
        if self.head:
            new_node = self.head
            self.head = self.head.next
            return new_node.data

    def peek(self):
        if self.head:
            return self.head.data
        
    def empty(self):
        return self.head is None


class FreqStack(object):

    def __init__(self):
        self.dictionary = dict()
        self.new_dict = dict()
        self.max_fr = 0

    def push(self, val):
        """
        :type val: int
        :rtype: None
        """
        if val not in self.dictionary:
            self.dictionary[val] = 1
        else:
            self.dictionary[val] += 1
        self.max_fr = max(self.max_fr,self.dictionary[val])
        if self.dictionary[val] not in self.new_dict:
            self.new_dict[self.dictionary[val]] = Stack()
            self.new_dict[self.dictionary[val]].push(val)
        else:
            self.new_dict[self.dictionary[val]].push(val)

    def pop(self):
        """
        :rtype: int
        """
        el = self.new_dict[self.max_fr].pop()
        self.dictionary[el] -= 1
        if self.dictionary[el] == 0:
            del self.dictionary[el]
        if self.new_dict[self.max_fr].empty():
            self.max_fr -= 1
        return el
