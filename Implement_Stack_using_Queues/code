class Node:
    def __init__(self,value):
        self.data = value
        self.next = None

class Queue:
    def __init__(self):
        self.front = None
        self.end = None

    def push(self, x):
        new_node = Node(x)
        if self.empty():
            self.front = new_node
            self.end = new_node
        else:
            self.end.next = new_node
            self.end = self.end.next

    def pop(self):
        if not self.empty():
            el = self.front.data
            self.front = self.front.next
            if self.front is None:
                self.end = None
            return el

    def peek(self):
        if not self.empty():
            return self.front.data

    def empty(self):
        return self.front is None

class MyStack(object):

    def __init__(self):
        self.queue_temp = Queue()
        self.queue_fin = Queue()

    def push(self, x):
        """
        :type x: int
        :rtype: None
        """
        self.queue_temp.push(x)
        while not self.queue_fin.empty():
            el = self.queue_fin.pop()
            self.queue_temp.push(el)
        self.queue_temp,self.queue_fin = self.queue_fin,self.queue_temp

    def pop(self):
        """
        :rtype: int
        """
        if not self.queue_fin.empty():
            return self.queue_fin.pop()

    

    def top(self):
        """
        :rtype: int
        """
        if not self.queue_fin.empty():
            return self.queue_fin.peek()

    def empty(self):
        """
        :rtype: bool
        """
        return self.queue_fin.empty()
